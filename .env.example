DEEPSEEK_API_KEY=

# 默认使用 DeepSeek。DeepSeek API 兼容 OpenAI ChatCompletions。
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# local_fallback 不调用在线大模型；deepseek/api/openai_compatible 会调用 LLM_API_KEY/DEEPSEEK_API_KEY。
GENERATION_MODE=local_fallback

# DeepSeek v4 可选深度思考配置。首跑建议关闭，节省延迟和费用。
DEEPSEEK_THINKING=false
DEEPSEEK_REASONING_EFFORT=high

# 联网搜索默认关闭。启用后 Agent 会在本地证据不足或问题明显需要时效信息时调用 Tavily。
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_DEPTH=basic
WEB_SEARCH_INCLUDE_RAW_CONTENT=false

# hybrid = 规则兜底 + LLM Router；rules = 只用规则路由。
ROUTER_MODE=hybrid
ROUTER_FORCE_WEB_ON_FRESHNESS=true

# Embedding 默认本地 Hugging Face 模型，不需要 API key；首次运行会下载模型。
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu

# 默认启用真实 BGE reranker。若机器性能或下载网络受限，可临时改为 mmr。
RERANKER_MODE=cross_encoder
RERANKER_MODEL=BAAI/bge-reranker-base

CHUNK_SIZE=700
CHUNK_OVERLAP=120
TOP_K=8
RERANK_TOP_K=4
VECTOR_WEIGHT=0.62
KEYWORD_WEIGHT=0.38
LLM_TEMPERATURE=0.1
